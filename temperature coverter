<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Temperature Converter</title>
  <style>
    :root {
      --bg-1: #0f172a;
      --bg-2: #1d4ed8;
      --card: rgba(15, 23, 42, 0.82);
      --field-bg: rgba(255, 255, 255, 0.08);
      --text: #e2e8f0;
      --muted: #94a3b8;
      --accent: #22d3ee;
      --accent-2: #14b8a6;
      --ring: rgba(34, 211, 238, 0.35);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: "Inter", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background:
        radial-gradient(circle at 0% 0%, rgba(34, 211, 238, 0.25), transparent 45%),
        radial-gradient(circle at 100% 100%, rgba(20, 184, 166, 0.2), transparent 40%),
        linear-gradient(135deg, var(--bg-1), var(--bg-2));
      color: var(--text);
      padding: 24px;
    }

    .converter-card {
      width: min(900px, 100%);
      border-radius: 20px;
      padding: 30px;
      background: var(--card);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(148, 163, 184, 0.25);
      box-shadow: 0 24px 50px rgba(2, 6, 23, 0.45);
    }

    .title {
      font-size: clamp(1.5rem, 2vw + 1rem, 2.3rem);
      font-weight: 800;
      letter-spacing: 0.3px;
      margin-bottom: 8px;
    }

    .subtitle {
      color: var(--muted);
      margin-bottom: 24px;
      font-size: 0.98rem;
    }

    .converter-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(160px, 1fr));
      gap: 16px;
    }

    .col {
      background: var(--field-bg);
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 14px;
      padding: 16px;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .col:hover {
      transform: translateY(-2px);
      border-color: rgba(34, 211, 238, 0.5);
    }

    .field-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--text);
      font-size: 0.95rem;
      margin-bottom: 10px;
      font-weight: 600;
    }

    .unit-chip {
      font-size: 0.75rem;
      color: var(--accent);
      background: rgba(34, 211, 238, 0.14);
      border: 1px solid rgba(34, 211, 238, 0.35);
      border-radius: 999px;
      padding: 4px 8px;
    }

    .col input {
      width: 100%;
      height: 44px;
      border-radius: 10px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(15, 23, 42, 0.6);
      color: #f8fafc;
      padding: 0 12px;
      font-size: 1rem;
      font-weight: 600;
      outline: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .col input::placeholder {
      color: #93a1b5;
      font-weight: 500;
    }

    .col input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 4px var(--ring);
    }

    .footer-note {
      margin-top: 18px;
      color: var(--muted);
      font-size: 0.85rem;
    }

    @media (max-width: 768px) {
      .converter-card {
        padding: 22px;
      }

      .converter-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <main class="converter-card">
    <h1 class="title">Temperature Converter</h1>
    <p class="subtitle">Instantly convert between Celsius, Fahrenheit, and Kelvin.</p>

    <section class="converter-row">
      <div class="col">
        <label class="field-label" for="fahrenheit">Fahrenheit <span class="unit-chip">°F</span></label>
        <input type="number" id="fahrenheit" placeholder="Enter Fahrenheit" />
      </div>

      <div class="col">
        <label class="field-label" for="celsius">Celsius <span class="unit-chip">°C</span></label>
        <input type="number" id="celsius" placeholder="Enter Celsius" />
      </div>

      <div class="col">
        <label class="field-label" for="kelvin">Kelvin <span class="unit-chip">K</span></label>
        <input type="number" id="kelvin" placeholder="Enter Kelvin" />
      </div>
    </section>

    <p class="footer-note">Tip: clear any input to reset all fields.</p>
  </main>

  <script>
    const celsius = document.getElementById("celsius");
    const fahrenheit = document.getElementById("fahrenheit");
    const kelvin = document.getElementById("kelvin");

    function roundToTwo(value) {
      return Number(value.toFixed(2));
    }

    function resetFields() {
      celsius.value = "";
      fahrenheit.value = "";
      kelvin.value = "";
    }

    celsius.oninput = function () {
      if (celsius.value === "") {
        resetFields();
        return;
      }

      const c = parseFloat(celsius.value);
      fahrenheit.value = roundToTwo((c * 9) / 5 + 32);
      kelvin.value = roundToTwo(c + 273.15);
    };

    fahrenheit.oninput = function () {
      if (fahrenheit.value === "") {
        resetFields();
        return;
      }

      const f = parseFloat(fahrenheit.value);
      celsius.value = roundToTwo(((f - 32) * 5) / 9);
      kelvin.value = roundToTwo(((f - 32) * 5) / 9 + 273.15);
    };

    kelvin.oninput = function () {
      if (kelvin.value === "") {
        resetFields();
        return;
      }

      const k = parseFloat(kelvin.value);
      fahrenheit.value = roundToTwo(((k - 273.15) * 9) / 5 + 32);
      celsius.value = roundToTwo(k - 273.15);
    };
  </script>
</body>
</html>
